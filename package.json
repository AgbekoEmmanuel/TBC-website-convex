{
  "name": "balance-church-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:website": "npm run dev -w apps/website",
    "dev:admin": "npm run dev -w apps/admin",
    "build:website": "npm run build -w apps/website",
    "build:admin": "npm run build -w apps/admin",
    "build": "npm run build:website && npm run build:admin && node scripts/bundle.mjs",
    "install:all": "npm install"
  },
  "devDependencies": {
    "convex": "^1.36.1",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.2.0",
    "node-fetch": "^3.3.2"
  }
}
